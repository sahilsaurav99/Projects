  term        Term      @relation(fields: [termId], references: [id], onDelete: Restrict)
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  publishedBy User?     @relation("TimetablePublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  entries TimetableEntry[]

  @@unique([sectionId, termId, version])
  @@index([instituteId, status])
  @@index([termId, status])
  @@index([sectionId, status])
  @@index([deletedAt])
  @@map("timetables")
}

model TimetableEntry {
  id                  String             @id @default(uuid())
  instituteId         String             @map("institute_id")
  timetableId         String             @map("timetable_id")
  subjectOfferingId   String             @map("subject_offering_id")
  facultyAssignmentId String?            @map("faculty_assignment_id")
  primaryFacultyId    String             @map("primary_faculty_id")
  dayOfWeek           DayOfWeek          @map("day_of_week")
  timeSlotId          String             @map("time_slot_id")
  roomId              String?            @map("room_id")
  labId               String?            @map("lab_id")
  entryType           TimetableEntryType @map("entry_type")
  deliveryMode        DeliveryMode       @default(OFFLINE) @map("delivery_mode")
  meetingUrl          String?            @map("meeting_url")
  weekParity          String?            @map("week_parity") // ALL | ODD | EVEN
  notes               String?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  deletedAt           DateTime?          @map("deleted_at")

  institute         Institute          @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  timetable         Timetable          @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  subjectOffering   SubjectOffering    @relation(fields: [subjectOfferingId], references: [id], onDelete: Restrict)
  facultyAssignment FacultyAssignment? @relation(fields: [facultyAssignmentId], references: [id], onDelete: SetNull)
  primaryFaculty    Faculty            @relation("TimetableEntryFaculty", fields: [primaryFacultyId], references: [id], onDelete: Restrict)
  timeSlot          TimeSlot           @relation(fields: [timeSlotId], references: [id], onDelete: Restrict)
  room              Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)
  lab               Lab?               @relation(fields: [labId], references: [id], onDelete: SetNull)

  classSessions ClassSession[]

  @@unique([timetableId, dayOfWeek, timeSlotId, weekParity])
  @@index([instituteId, dayOfWeek])
  @@index([primaryFacultyId, dayOfWeek, timeSlotId])
  @@index([subjectOfferingId])
  @@index([roomId, dayOfWeek, timeSlotId])
  @@index([labId, dayOfWeek, timeSlotId])
  @@index([deletedAt])
  @@map("timetable_entries")
}

model ClassSession {
  id                  String             @id @default(uuid())
  instituteId         String             @map("institute_id")
  timetableEntryId    String?            @map("timetable_entry_id")
  subjectOfferingId   String             @map("subject_offering_id")
  facultyId           String             @map("faculty_id")
  sectionId           String             @map("section_id")
  roomId              String?            @map("room_id")
  labId               String?            @map("lab_id")
  sessionDate         DateTime           @map("session_date") @db.Date
  startAt             DateTime           @map("start_at")
  endAt               DateTime           @map("end_at")
  entryType           TimetableEntryType @map("entry_type")
  deliveryMode        DeliveryMode       @default(OFFLINE) @map("delivery_mode")
  status              ClassSessionStatus @default(SCHEDULED)
  topic               String?
  summary             String?
  cancellationReason  String?            @map("cancellation_reason")
  rescheduledToId     String?            @unique @map("rescheduled_to_id")
  meetingUrl          String?            @map("meeting_url")
  meetingRecordingUrl String?            @map("meeting_recording_url")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  deletedAt           DateTime?          @map("deleted_at")

  institute       Institute       @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  timetableEntry  TimetableEntry? @relation(fields: [timetableEntryId], references: [id], onDelete: SetNull)
  subjectOffering SubjectOffering @relation(fields: [subjectOfferingId], references: [id], onDelete: Restrict)
  faculty         Faculty         @relation("ClassSessionFaculty", fields: [facultyId], references: [id], onDelete: Restrict)
  section         Section         @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  room            Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  lab             Lab?            @relation(fields: [labId], references: [id], onDelete: SetNull)
  rescheduledTo   ClassSession?   @relation("ClassSessionReschedule", fields: [rescheduledToId], references: [id], onDelete: SetNull)
