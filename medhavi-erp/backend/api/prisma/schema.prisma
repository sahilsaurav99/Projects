  attendanceSession AttendanceSession?

  @@index([instituteId, sessionDate])
  @@index([facultyId, sessionDate])
  @@index([sectionId, sessionDate])
  @@index([subjectOfferingId, sessionDate])
  @@index([status, sessionDate])
  @@index([deletedAt])
  @@map("class_sessions")
}

