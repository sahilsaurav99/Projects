model Institute {
  id           String          @id @default(uuid()) @db.Uuid
  code         String          @unique
  name         String
  legalName    String?         @map("legal_name")
  domain       String?         @unique
  logoFileId   String?         @map("logo_file_id") @db.Uuid
  timezone     String          @default("Asia/Kolkata")
  locale       String          @default("en-IN")
  status       InstituteStatus @default(ACTIVE)
  contactEmail String?         @map("contact_email")
  contactPhone String?         @map("contact_phone")
  addressLine1 String?         @map("address_line1")
  addressLine2 String?         @map("address_line2")
  city         String?
  state        String?
  country      String?
  postalCode   String?         @map("postal_code")
  metadata     Json?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  campuses      Campus[]
  schools       School[]
  departments   Department[]
  users         User[]
  roles         Role[]
  workflows     WorkflowDefinition[]
  notifications Notification[]
  settings      Setting[]
  files         FileObject[]
  auditLogs     AuditLog[]
  logoFile      FileObject?          @relation("InstituteLogo", fields: [logoFileId], references: [id], onDelete: SetNull)

  // --- V1.2 MERGED: additive back-relations from V2.2 overlay ---
  idempotencyKeys             IdempotencyKey[]
  featureFlags                InstituteFeatureFlag[]
  notificationProviderConfigs NotificationProviderConfig[]
  mentorAssignments           MentorAssignment[]
  onlineExamMedia             OnlineExamMedia[]
  approvalEscalations         ApprovalEscalation[]

  // --- Back-relations (hotfix) ---
  academicYears         AcademicYear[]
  terms                 Term[]
  programs              Program[]
  batches               Batch[]
  sections              Section[]
  subjects              Subject[]
  subjectOfferings      SubjectOffering[]
  faculties             Faculty[]
  facultyAssignments    FacultyAssignment[]
  mentorships           Mentorship[]
  facultyAdvisors       FacultyAdvisor[]
  advisorStudents       AdvisorStudent[]
  students              Student[]
  rooms                 Room[]
  labs                  Lab[]
  timeSlots             TimeSlot[]
  timetables            Timetable[]
  timetableEntries      TimetableEntry[]
  classSessions         ClassSession[]
  facultyWorkloads      FacultyWorkload[]
  courses               Course[]
  courseEnrollments     CourseEnrollment[]
  courseModules         CourseModule[]
  lmsSessions           LmsSession[]
  resources             Resource[]
  discussionThreads     DiscussionThread[]
  discussionComments    DiscussionComment[]
  attendanceSessions    AttendanceSession[]
  attendanceRecords     AttendanceRecord[]
  assignmentCategories  AssignmentCategory[]
  assignments           Assignment[]
  assignmentSubmissions AssignmentSubmission[]
  quizBanks             QuizBank[]
  quizQuestions         QuizQuestion[]

  // --- Back-relations (hotfix) ---
  quizs                   Quiz[]
  quizAttempts            QuizAttempt[]
  quizResults             QuizResult[]
  exams                   Exam[]
  examSchedules           ExamSchedule[]
  invigilationAssignments InvigilationAssignment[]
  hallTickets             HallTicket[]
  marksEntries            MarksEntry[]
  moderations             Moderation[]
  results                 Result[]
  transcripts             Transcript[]
  revaluationRequests     RevaluationRequest[]
  registrationCycles      RegistrationCycle[]
  courseRegistrations     CourseRegistration[]
  registrationSubjects    RegistrationSubject[]
  feeStructures           FeeStructure[]
  invoices                Invoice[]
  payments                Payment[]
  scholarships            Scholarship[]
  wallets                 Wallet[]
  walletTransactions      WalletTransaction[]
  feeWaivers              FeeWaiver[]
  documents               Document[]
  certificates            Certificate[]
  helpCenterArticles      HelpCenterArticle[]
  tickets                 Ticket[]
  books                   Book[]
  bookCopies              BookCopy[]
  bookIssues              BookIssue[]
  bookReservations        BookReservation[]
  libraryFines            LibraryFine[]
  hostels                 Hostel[]
  hostelRooms             HostelRoom[]
  hostelAllocations       HostelAllocation[]
  hostelLeaveRequests     HostelLeaveRequest[]
  transportRoutes         TransportRoute[]
  transportVehicles       TransportVehicle[]
  transportStops          TransportStop[]
  transportPasses         TransportPass[]
  clubs                   Club[]

  // --- Back-relations (hotfix) ---
