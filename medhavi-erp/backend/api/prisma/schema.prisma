model CourseModule {
  id          String       @id @default(uuid())
  instituteId String       @map("institute_id")
  courseId    String       @map("course_id")
  parentId    String?      @map("parent_id")
  title       String
  description String?      @db.Text
  orderIndex  Int          @map("order_index")
  status      ModuleStatus @default(DRAFT)
  unlocksAt   DateTime?    @map("unlocks_at")
  locksAt     DateTime?    @map("locks_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  institute Institute      @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parent    CourseModule?  @relation("ModuleHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  CourseModule[] @relation("ModuleHierarchy")

  sessions  LmsSession[]
  resources Resource[]

  @@unique([courseId, parentId, orderIndex])
  @@index([instituteId, courseId])
  @@index([deletedAt])
  @@map("course_modules")
}

model LmsSession {
  id              String         @id @default(uuid())
  instituteId     String         @map("institute_id")
  moduleId        String         @map("module_id")
  title           String
  description     String?        @db.Text
  type            LmsSessionType
  orderIndex      Int            @map("order_index")
  durationMin     Int?           @map("duration_min")
  scheduledAt     DateTime?      @map("scheduled_at")
  meetingUrl      String?        @map("meeting_url")
  recordingUrl    String?        @map("recording_url")
  contentMarkdown String?        @map("content_markdown") @db.Text
  isMandatory     Boolean        @default(true) @map("is_mandatory")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  institute Institute    @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  resources Resource[]

  @@unique([moduleId, orderIndex])
  @@index([instituteId, type])
  @@index([deletedAt])
  @@map("lms_sessions")
}

model Resource {
  id             String       @id @default(uuid())
  instituteId    String       @map("institute_id")
  courseId       String?      @map("course_id")
  moduleId       String?      @map("module_id")
  sessionId      String?      @map("session_id")
  title          String
  type           ResourceType
  url            String?
  fileObjectId   String?      @map("file_object_id")
  sizeBytes      BigInt?      @map("size_bytes")
  mimeType       String?      @map("mime_type")
  description    String?      @db.Text
  isDownloadable Boolean      @default(true) @map("is_downloadable")
  orderIndex     Int          @default(0) @map("order_index")
  createdById    String?      @map("created_by_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  institute  Institute     @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  course     Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module     CourseModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  session    LmsSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileObject FileObject?   @relation("ResourceFile", fields: [fileObjectId], references: [id], onDelete: SetNull)
  createdBy  User?         @relation("ResourceCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([instituteId, type])
  @@index([courseId])
  @@index([moduleId])
  @@index([sessionId])
  @@index([deletedAt])
  @@map("resources")
}

