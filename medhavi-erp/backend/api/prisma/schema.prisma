model HallTicket {
  id            String           @id @default(uuid())
  instituteId   String           @map("institute_id")
  examId        String           @map("exam_id")
  studentId     String           @map("student_id")
  ticketNumber  String           @map("ticket_number")
  status        HallTicketStatus @default(GENERATED)
  qrPayload     String?          @map("qr_payload")
  issuedAt      DateTime?        @map("issued_at")
  fileObjectId  String?          @map("file_object_id")
  blockedReason String?          @map("blocked_reason")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  institute  Institute   @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  exam       Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  fileObject FileObject? @relation("HallTicketFile", fields: [fileObjectId], references: [id], onDelete: SetNull)

  @@unique([examId, studentId])
  @@unique([instituteId, ticketNumber])
  @@index([studentId])
  @@index([status])
  @@index([deletedAt])
  @@map("hall_tickets")
}

model MarksEntry {
  id                 String           @id @default(uuid())
  instituteId        String           @map("institute_id")
  examId             String           @map("exam_id")
  subjectOfferingId  String           @map("subject_offering_id")
  enteredByFacultyId String           @map("entered_by_faculty_id")
  status             MarksEntryStatus @default(DRAFT)
  totalStudents      Int              @map("total_students")
  enteredCount       Int              @default(0) @map("entered_count")
  submittedAt        DateTime?        @map("submitted_at")
  approvedAt         DateTime?        @map("approved_at")
  approvedByUserId   String?          @map("approved_by_user_id")
  filePath           String?          @map("file_path")
  remarks            String?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")

  institute        Institute       @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  exam             Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectOffering  SubjectOffering @relation(fields: [subjectOfferingId], references: [id], onDelete: Restrict)
  enteredByFaculty Faculty         @relation("MarksEnteredBy", fields: [enteredByFacultyId], references: [id], onDelete: Restrict)
  approvedBy       User?           @relation("MarksApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  moderation Moderation?

  @@unique([examId, subjectOfferingId])
  @@index([instituteId, status])
  @@index([enteredByFacultyId])
  @@index([deletedAt])
  @@map("marks_entries")
}

model Moderation {
  id               String    @id @default(uuid())
  instituteId      String    @map("institute_id")
  marksEntryId     String    @unique @map("marks_entry_id")
  moderatorUserId  String    @map("moderator_user_id")
  scalingFactor    Decimal?  @map("scaling_factor") @db.Decimal(6, 4)
  graceMarks       Decimal?  @map("grace_marks") @db.Decimal(6, 2)
  cutoffAdjustment Decimal?  @map("cutoff_adjustment") @db.Decimal(6, 2)
  rationale        String?   @db.Text
  beforeStatsJson  Json?     @map("before_stats_json")
  afterStatsJson   Json?     @map("after_stats_json")
  moderatedAt      DateTime  @default(now()) @map("moderated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  institute  Institute  @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  marksEntry MarksEntry @relation(fields: [marksEntryId], references: [id], onDelete: Cascade)
  moderator  User       @relation("Moderator", fields: [moderatorUserId], references: [id], onDelete: Restrict)

  @@index([instituteId])
  @@index([deletedAt])
  @@map("moderations")
}

model Result {
  id                String             @id @default(uuid())
  instituteId       String             @map("institute_id")
  examId            String             @map("exam_id")
  subjectOfferingId String             @map("subject_offering_id")
  studentId         String             @map("student_id")
  marksObtained     Decimal?           @map("marks_obtained") @db.Decimal(8, 2)
  maxMarks          Decimal            @map("max_marks") @db.Decimal(8, 2)
  percentage        Decimal?           @db.Decimal(5, 2)
  gradePoint        Decimal?           @map("grade_point") @db.Decimal(4, 2)
  gradeLetter       String?            @map("grade_letter")
  credits           Decimal?           @db.Decimal(4, 2)
  creditPoints      Decimal?           @map("credit_points") @db.Decimal(6, 2)
  outcome           ResultGradeOutcome @default(PENDING)
  status            ResultStatus       @default(COMPUTED)
  publishedAt       DateTime?          @map("published_at")
  revisedAt         DateTime?          @map("revised_at")
  isMakeup          Boolean            @default(false) @map("is_makeup")
  remark            String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  institute       Institute       @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  exam            Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectOffering SubjectOffering @relation(fields: [subjectOfferingId], references: [id], onDelete: Restrict)
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Restrict)

  revaluations RevaluationRequest[]

  @@unique([examId, subjectOfferingId, studentId])
  @@index([instituteId, status])
  @@index([studentId, status])
  @@index([examId])
  @@index([outcome])
  @@index([deletedAt])
  @@map("results")
}

model Transcript {
  id                 String    @id @default(uuid())
  instituteId        String    @map("institute_id")
  studentId          String    @map("student_id")
  termId             String?   @map("term_id")
  isCumulative       Boolean   @default(false) @map("is_cumulative")
  totalCreditsEarned Decimal?  @map("total_credits_earned") @db.Decimal(6, 2)
  sgpa               Decimal?  @db.Decimal(4, 2)
  cgpa               Decimal?  @db.Decimal(4, 2)
  rank               Int?
  classification     String?
  issuedAt           DateTime  @default(now()) @map("issued_at")
  issuedByUserId     String?   @map("issued_by_user_id")
  fileObjectId       String?   @map("file_object_id")
  verificationCode   String    @unique @map("verification_code")
  payloadJson        Json?     @map("payload_json")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  institute  Institute   @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  term       Term?       @relation(fields: [termId], references: [id], onDelete: SetNull)
  issuedBy   User?       @relation("TranscriptIssuer", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  fileObject FileObject? @relation("TranscriptFile", fields: [fileObjectId], references: [id], onDelete: SetNull)

  @@unique([studentId, termId, isCumulative])
  @@index([instituteId])
  @@index([studentId])
  @@index([deletedAt])
  @@map("transcripts")
}

model RevaluationRequest {
  id              String            @id @default(uuid())
  instituteId     String            @map("institute_id")
  examId          String            @map("exam_id")
  resultId        String            @map("result_id")
  studentId       String            @map("student_id")
  reason          String            @db.Text
  status          RevaluationStatus @default(REQUESTED)
  feeAmount       Decimal?          @map("fee_amount") @db.Decimal(10, 2)
  feePaidAt       DateTime?         @map("fee_paid_at")
  invoiceId       String?           @map("invoice_id")
  oldMarks        Decimal?          @map("old_marks") @db.Decimal(8, 2)
  newMarks        Decimal?          @map("new_marks") @db.Decimal(8, 2)
  decidedAt       DateTime?         @map("decided_at")
  decidedByUserId String?           @map("decided_by_user_id")
  remarks         String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  exam      Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  result    Result    @relation(fields: [resultId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  invoice   Invoice?  @relation("RevaluationInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)
  decidedBy User?     @relation("RevaluationDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([instituteId, status])
  @@index([studentId])
  @@index([examId])
  @@index([deletedAt])
  @@map("revaluation_requests")
}

enum RegistrationCycleStatus {
  PLANNED
  OPEN
  CLOSED
  ARCHIVED

  @@map("registration_cycle_status")
}

enum CourseRegistrationStatus {
  DRAFT
  SUBMITTED
  ADVISOR_APPROVED
  HOD_APPROVED
  REGISTERED
  REJECTED
  WITHDRAWN

  @@map("course_registration_status")
}

enum RegistrationSubjectStatus {
  ADDED
  DROPPED
  WAITLISTED
  CONFIRMED
  AUDIT
  WITHDRAWN

  @@map("registration_subject_status")
}

enum FeeStructureStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("fee_structure_status")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  WRITTEN_OFF

  @@map("invoice_status")
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  NET_BANKING
  WALLET
  CHEQUE
  DEMAND_DRAFT
  BANK_TRANSFER
  SCHOLARSHIP
  WAIVER
  ADJUSTMENT

  @@map("payment_method")
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CHARGEBACK
  CANCELLED

  @@map("payment_status")
}

enum ScholarshipStatus {
  APPLIED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
  REVOKED

  @@map("scholarship_status")
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED

  @@map("wallet_status")
}

enum WalletTxnType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
  REFUND
  ADJUSTMENT

  @@map("wallet_txn_type")
}

enum WaiverStatus {
  REQUESTED
  APPROVED
  REJECTED
  APPLIED
  REVOKED

  @@map("waiver_status")
}

model RegistrationCycle {
  id              String                  @id @default(uuid())
  instituteId     String                  @map("institute_id")
  termId          String                  @map("term_id")
  name            String
  opensAt         DateTime                @map("opens_at")
  closesAt        DateTime                @map("closes_at")
  addDropClosesAt DateTime?               @map("add_drop_closes_at")
  status          RegistrationCycleStatus @default(PLANNED)
  minCredits      Decimal?                @map("min_credits") @db.Decimal(5, 2)
  maxCredits      Decimal?                @map("max_credits") @db.Decimal(5, 2)
  rulesJson       Json?                   @map("rules_json")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  deletedAt       DateTime?               @map("deleted_at")

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  term      Term      @relation(fields: [termId], references: [id], onDelete: Restrict)

  registrations CourseRegistration[]

  @@unique([termId, name])
  @@index([instituteId, status])
  @@index([deletedAt])
  @@map("registration_cycles")
}

model CourseRegistration {
  id                String                   @id @default(uuid())
  instituteId       String                   @map("institute_id")
  cycleId           String                   @map("cycle_id")
  studentId         String                   @map("student_id")
  termId            String                   @map("term_id")
  status            CourseRegistrationStatus @default(DRAFT)
  totalCredits      Decimal                  @default(0) @map("total_credits") @db.Decimal(5, 2)
  submittedAt       DateTime?                @map("submitted_at")
  advisorApprovedAt DateTime?                @map("advisor_approved_at")
  advisorUserId     String?                  @map("advisor_user_id")
  hodApprovedAt     DateTime?                @map("hod_approved_at")
  hodUserId         String?                  @map("hod_user_id")
  rejectedReason    String?                  @map("rejected_reason")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  deletedAt         DateTime?                @map("deleted_at")

  institute Institute         @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  cycle     RegistrationCycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term      Term              @relation(fields: [termId], references: [id], onDelete: Restrict)
  advisor   User?             @relation("RegAdvisor", fields: [advisorUserId], references: [id], onDelete: SetNull)
  hod       User?             @relation("RegHod", fields: [hodUserId], references: [id], onDelete: SetNull)

  subjects RegistrationSubject[]

  @@unique([cycleId, studentId])
  @@index([instituteId, status])
  @@index([studentId, termId])
  @@index([deletedAt])
  @@map("course_registrations")
}

model RegistrationSubject {
  id                String                    @id @default(uuid())
  instituteId       String                    @map("institute_id")
  registrationId    String                    @map("registration_id")
  subjectOfferingId String                    @map("subject_offering_id")
  status            RegistrationSubjectStatus @default(ADDED)
  isElective        Boolean                   @default(false) @map("is_elective")
  isAudit           Boolean                   @default(false) @map("is_audit")
  credits           Decimal                   @db.Decimal(4, 2)
  preferenceOrder   Int?                      @map("preference_order")
  addedAt           DateTime                  @default(now()) @map("added_at")
  droppedAt         DateTime?                 @map("dropped_at")
  reason            String?
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  deletedAt         DateTime?                 @map("deleted_at")

  institute       Institute          @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  registration    CourseRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  subjectOffering SubjectOffering    @relation(fields: [subjectOfferingId], references: [id], onDelete: Restrict)

  @@unique([registrationId, subjectOfferingId])
  @@index([instituteId, status])
  @@index([subjectOfferingId, status])
  @@index([deletedAt])
  @@map("registration_subjects")
}

model FeeStructure {
  id             String             @id @default(uuid())
  instituteId    String             @map("institute_id")
  programId      String?            @map("program_id")
  batchId        String?            @map("batch_id")
  academicYearId String             @map("academic_year_id")
  termId         String?            @map("term_id")
  name           String
  description    String?
  totalAmount    Decimal            @map("total_amount") @db.Decimal(12, 2)
  currency       String             @default("INR")
  componentsJson Json               @map("components_json")
  dueDate        DateTime?          @map("due_date") @db.Date
  status         FeeStructureStatus @default(DRAFT)
  effectiveFrom  DateTime           @map("effective_from") @db.Date
  effectiveTo    DateTime?          @map("effective_to") @db.Date
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  institute    Institute    @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  batch        Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  term         Term?        @relation(fields: [termId], references: [id], onDelete: SetNull)

  invoices Invoice[]

  @@index([instituteId, status])
  @@index([programId, batchId, academicYearId])
  @@index([deletedAt])
  @@map("fee_structures")
}

model Invoice {
  id             String        @id @default(uuid())
  instituteId    String        @map("institute_id")
  studentId      String        @map("student_id")
  feeStructureId String?       @map("fee_structure_id")
  termId         String?       @map("term_id")
  invoiceNumber  String        @map("invoice_number")
  status         InvoiceStatus @default(DRAFT)
  subTotal       Decimal       @map("sub_total") @db.Decimal(12, 2)
  discountTotal  Decimal       @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal       Decimal       @default(0) @map("tax_total") @db.Decimal(12, 2)
  grandTotal     Decimal       @map("grand_total") @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountDue      Decimal       @map("amount_due") @db.Decimal(12, 2)
  currency       String        @default("INR")
  issuedAt       DateTime?     @map("issued_at")
  dueDate        DateTime?     @map("due_date") @db.Date
  paidAt         DateTime?     @map("paid_at")
  cancelledAt    DateTime?     @map("cancelled_at")
  lineItemsJson  Json          @map("line_items_json")
  notes          String?
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  institute    Institute     @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id], onDelete: SetNull)
  term         Term?         @relation(fields: [termId], references: [id], onDelete: SetNull)

  payments     Payment[]
  waivers      FeeWaiver[]
  revaluations RevaluationRequest[] @relation("RevaluationInvoice")

  @@unique([instituteId, invoiceNumber])
  @@index([instituteId, status])
  @@index([studentId, status])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("invoices")
}

model Payment {
  id               String        @id @default(uuid())
  instituteId      String        @map("institute_id")
  invoiceId        String?       @map("invoice_id")
  studentId        String        @map("student_id")
  paymentNumber    String        @map("payment_number")
  method           PaymentMethod
  status           PaymentStatus @default(INITIATED)
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("INR")
  gatewayName      String?       @map("gateway_name")
  gatewayTxnId     String?       @unique @map("gateway_txn_id")
  gatewayResponse  Json?         @map("gateway_response")
  paidAt           DateTime?     @map("paid_at")
  refundedAt       DateTime?     @map("refunded_at")
  refundAmount     Decimal?      @map("refund_amount") @db.Decimal(12, 2)
  receiptUrl       String?       @map("receipt_url")
  receivedByUserId String?       @map("received_by_user_id")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  institute  Institute @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  receivedBy User?     @relation("PaymentReceiver", fields: [receivedByUserId], references: [id], onDelete: SetNull)

  walletTransactions WalletTransaction[]

  @@unique([instituteId, paymentNumber])
  @@index([instituteId, status])
  @@index([studentId, status])
  @@index([invoiceId])
  @@index([deletedAt])
  @@map("payments")
}

model Scholarship {
  id                 String            @id @default(uuid())
  instituteId        String            @map("institute_id")
  studentId          String            @map("student_id")
  academicYearId     String            @map("academic_year_id")
  name               String
  sponsor            String?
  amount             Decimal           @db.Decimal(12, 2)
  currency           String            @default("INR")
  status             ScholarshipStatus @default(APPLIED)
  appliedAt          DateTime          @default(now()) @map("applied_at")
  approvedAt         DateTime?         @map("approved_at")
  approvedByUserId   String?           @map("approved_by_user_id")
  disbursedAt        DateTime?         @map("disbursed_at")
  disbursementMethod String?           @map("disbursement_method")
  documentsJson      Json?             @map("documents_json")
  remarks            String?
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")

  institute    Institute    @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  approvedBy   User?        @relation("ScholarshipApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([instituteId, status])
  @@index([studentId])
  @@index([deletedAt])
  @@map("scholarships")
}

model Wallet {
  id          String       @id @default(uuid())
  instituteId String       @map("institute_id")
  studentId   String       @unique @map("student_id")
  balance     Decimal      @default(0) @db.Decimal(12, 2)
  holdAmount  Decimal      @default(0) @map("hold_amount") @db.Decimal(12, 2)
  currency    String       @default("INR")
  status      WalletStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  transactions WalletTransaction[]

  @@index([instituteId, status])
  @@index([deletedAt])
  @@map("wallets")
}

model WalletTransaction {
  id              String        @id @default(uuid())
  instituteId     String        @map("institute_id")
  walletId        String        @map("wallet_id")
  paymentId       String?       @map("payment_id")
  type            WalletTxnType
  amount          Decimal       @db.Decimal(12, 2)
  balanceAfter    Decimal       @map("balance_after") @db.Decimal(12, 2)
  reference       String?
  description     String?
  metadata        Json?
  createdByUserId String?       @map("created_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  deletedAt       DateTime?     @map("deleted_at")

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  wallet    Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payment   Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("WalletTxnCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([instituteId, walletId])
  @@index([walletId, createdAt])
  @@index([type])
  @@index([deletedAt])
  @@map("wallet_transactions")
}

model FeeWaiver {
  id                String       @id @default(uuid())
  instituteId       String       @map("institute_id")
  studentId         String       @map("student_id")
  invoiceId         String?      @map("invoice_id")
  amount            Decimal      @db.Decimal(12, 2)
  reason            String       @db.Text
  status            WaiverStatus @default(REQUESTED)
  requestedByUserId String       @map("requested_by_user_id")
  approvedByUserId  String?      @map("approved_by_user_id")
  approvedAt        DateTime?    @map("approved_at")
  appliedAt         DateTime?    @map("applied_at")
  remarks           String?
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")

