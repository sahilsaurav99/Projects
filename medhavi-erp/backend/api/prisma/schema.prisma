  @@index([deletedAt])
  @@map("institutes")
}

model Campus {
  id           String        @id @default(uuid()) @db.Uuid
  instituteId  String        @map("institute_id") @db.Uuid
  code         String
  name         String
  isMain       Boolean       @default(false) @map("is_main")
  addressLine1 String?       @map("address_line1")
  addressLine2 String?       @map("address_line2")
  city         String?
  state        String?
  country      String?
  postalCode   String?       @map("postal_code")
  latitude     Decimal?      @db.Decimal(10, 7)
  longitude    Decimal?      @db.Decimal(10, 7)
  status       OrgUnitStatus @default(ACTIVE)
  metadata     Json?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  schools     School[]
  departments Department[]

  // --- Back-relations (hotfix) ---
  programs  Program[]
  faculties Faculty[]
  rooms     Room[]
  labs      Lab[]

  // --- Back-relations (hotfix) ---
  hostels Hostel[]

  @@unique([instituteId, code], name: "uq_campus_institute_code")
  @@index([instituteId, status])
  @@index([deletedAt])
  @@map("campuses")
}

model School {
  id          String        @id @default(uuid()) @db.Uuid
  instituteId String        @map("institute_id") @db.Uuid
  campusId    String        @map("campus_id") @db.Uuid
  code        String
  name        String
  shortName   String?       @map("short_name")
  deanUserId  String?       @map("dean_user_id") @db.Uuid
  status      OrgUnitStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  campus      Campus       @relation(fields: [campusId], references: [id], onDelete: Restrict)
  dean        User?        @relation("SchoolDean", fields: [deanUserId], references: [id], onDelete: SetNull)
  departments Department[]

  // --- Back-relations (hotfix) ---
  programs  Program[]
  faculties Faculty[]

  @@unique([instituteId, code], name: "uq_school_institute_code")
  @@index([campusId, status])
  @@index([deletedAt])
  @@map("schools")
}

model Department {
  id          String        @id @default(uuid()) @db.Uuid
  instituteId String        @map("institute_id") @db.Uuid
  campusId    String        @map("campus_id") @db.Uuid
  schoolId    String        @map("school_id") @db.Uuid
  code        String
  name        String
  shortName   String?       @map("short_name")
  hodUserId   String?       @map("hod_user_id") @db.Uuid
  status      OrgUnitStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  campus    Campus    @relation(fields: [campusId], references: [id], onDelete: Restrict)
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  hod       User?     @relation("DepartmentHod", fields: [hodUserId], references: [id], onDelete: SetNull)

  // --- Back-relations (hotfix) ---
  programs         Program[]
  subjects         Subject[]
  subjectOfferings SubjectOffering[]
  faculties        Faculty[]

  // --- Back-relations (hotfix) ---
  researchProjects ResearchProject[]

  @@unique([instituteId, code], name: "uq_dept_institute_code")
  @@unique([schoolId, code], name: "uq_dept_school_code")
  @@index([campusId, status])
  @@index([schoolId, status])
  @@index([deletedAt])
  @@map("departments")
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  instituteId        String?    @map("institute_id") @db.Uuid // null = platform user (Super Admin)
  email              String     @unique
  emailVerifiedAt    DateTime?  @map("email_verified_at")
  phone              String?    @unique
  phoneVerifiedAt    DateTime?  @map("phone_verified_at")
  firstName          String     @map("first_name")
  middleName         String?    @map("middle_name")
  lastName           String     @map("last_name")
  displayName        String?    @map("display_name")
  gender             Gender?
  dateOfBirth        DateTime?  @map("date_of_birth") @db.Date
  avatarFileId       String?    @map("avatar_file_id") @db.Uuid
  status             UserStatus @default(PENDING_VERIFICATION)
  lockedUntil        DateTime?  @map("locked_until")
  failedLoginCount   Int        @default(0) @map("failed_login_count")
  lastLoginAt        DateTime?  @map("last_login_at")
  lastLoginIp        String?    @map("last_login_ip")
  mfaEnabled         Boolean    @default(false) @map("mfa_enabled")
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  preferredLanguage  String     @default("en") @map("preferred_language")
  timezone           String?
  metadata           Json?
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")

  institute               Institute?               @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  avatarFile              FileObject?              @relation("UserAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)
  credentials             AuthCredential[]
  sessions                Session[]
  loginAttempts           LoginAttempt[]
  mfaFactors              MfaFactor[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  securityEvents          SecurityEvent[]
  userRoles               UserRole[]
  userScopes              UserScope[]
  rolesGranted            UserRole[]               @relation("RoleGrantedBy")
  scopesGranted           UserScope[]              @relation("ScopeGrantedBy")
  auditLogs               AuditLog[]
  notifications           Notification[]
  notificationPrefs       NotificationPreference[]
  workflowInstances       WorkflowInstance[]       @relation("WorkflowInitiator")
  workflowActions         WorkflowAction[]
  uploadedFiles           FileObject[]             @relation("FileUploader")
  fileAccessGrants        FileAccessGrant[]        @relation("FileGrantedTo")
  fileGrantsIssued        FileAccessGrant[]        @relation("FileGrantedBy")
  settingsAuthored        Setting[]                @relation("SettingUpdatedBy")
  headedDepartments       Department[]             @relation("DepartmentHod")
  deanedSchools           School[]                 @relation("SchoolDean")

  // --- V1.2 MERGED: additive back-relations from V2.2 overlay ---
  idempotencyKeys     IdempotencyKey[]
  resolvedEscalations ApprovalEscalation[] @relation("EscalationResolver")

  // --- Back-relations (hotfix) ---
  sectionClassReps              Section[]           @relation("SectionClassRep")
  faculties                     Faculty[]
  facultyAssignmentAssignedBies FacultyAssignment[] @relation("FacultyAssignmentAssignedBy")
  facultyAssignmentApprovedBies FacultyAssignment[] @relation("FacultyAssignmentApprovedBy")
  mentorshipAssignedBies        Mentorship[]        @relation("MentorshipAssignedBy")
  facultyAdvisorAssignedBies    FacultyAdvisor[]    @relation("FacultyAdvisorAssignedBy")
  advisorStudentAssignedBies    AdvisorStudent[]    @relation("AdvisorStudentAssignedBy")
  studentUsers                  Student[]           @relation("StudentUser")
  timetablePublishers           Timetable[]         @relation("TimetablePublisher")
  resourceCreators              Resource[]          @relation("ResourceCreator")
  threadAuthors                 DiscussionThread[]  @relation("ThreadAuthor")
  commentAuthors                DiscussionComment[] @relation("CommentAuthor")
  attendanceMarkers             AttendanceRecord[]  @relation("AttendanceMarker")

  // --- Back-relations (hotfix) ---
  quizGraders          QuizResult[]         @relation("QuizGrader")
  examControllers      Exam[]               @relation("ExamController")
  marksApprovers       MarksEntry[]         @relation("MarksApprover")
  moderators           Moderation[]         @relation("Moderator")
  transcriptIssuers    Transcript[]         @relation("TranscriptIssuer")
  revaluationDeciders  RevaluationRequest[] @relation("RevaluationDecider")
  regAdvisors          CourseRegistration[] @relation("RegAdvisor")
  regHods              CourseRegistration[] @relation("RegHod")
  paymentReceivers     Payment[]            @relation("PaymentReceiver")
  scholarshipApprovers Scholarship[]        @relation("ScholarshipApprover")
  walletTxnCreators    WalletTransaction[]  @relation("WalletTxnCreator")
  waiverRequesters     FeeWaiver[]          @relation("WaiverRequester")
  waiverApprovers      FeeWaiver[]          @relation("WaiverApprover")
  documentOwners       Document[]           @relation("DocumentOwner")
  certificateIssuers   Certificate[]        @relation("CertificateIssuer")
  helpArticleAuthors   HelpCenterArticle[]  @relation("HelpArticleAuthor")
  ticketRaisers        Ticket[]             @relation("TicketRaiser")
  ticketAssignees      Ticket[]             @relation("TicketAssignee")
  bookBorrowers        BookIssue[]          @relation("BookBorrower")
  bookIssuers          BookIssue[]          @relation("BookIssuer")
  bookReturners        BookIssue[]          @relation("BookReturner")
  bookReservers        BookReservation[]    @relation("BookReserver")
  libraryFineUsers     LibraryFine[]        @relation("LibraryFineUser")
  libraryFineWaivers   LibraryFine[]        @relation("LibraryFineWaiver")
  hostelWardens        Hostel[]             @relation("HostelWarden")
  hostelAllocators     HostelAllocation[]   @relation("HostelAllocator")
  hostelLeaveApprovers HostelLeaveRequest[] @relation("HostelLeaveApprover")

  // --- Back-relations (hotfix) ---
  clubPresidents    Club[]              @relation("ClubPresident")
  eventOrganizers   Event[]             @relation("EventOrganizer")
  eventRegistrants  EventRegistration[] @relation("EventRegistrant")
  feedbackAuthors   Feedback[]          @relation("FeedbackAuthor")
  driveCoordinators PlacementDrive[]    @relation("DriveCoordinator")

  @@index([instituteId, status])
  @@index([status])
  @@index([deletedAt])
  @@index([lastLoginAt])
  @@map("users")
}

model Role {
  id           String    @id @default(uuid()) @db.Uuid
  instituteId  String?   @map("institute_id") @db.Uuid // null = system/global role
  key          String // e.g. SUPER_ADMIN, CAMPUS_ADMIN, HOD, FACULTY, STUDENT
  name         String
  description  String?
  kind         RoleKind  @default(SYSTEM)
  defaultScope ScopeType @default(INSTITUTE) @map("default_scope")
  rank         Int       @default(100) // for hierarchical comparison
  isAssignable Boolean   @default(true) @map("is_assignable")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  institute   Institute?       @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  userRoles   UserRole[]

  @@unique([instituteId, key], name: "uq_role_institute_key")
  @@index([kind])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique // e.g. attendance.mark, results.publish
  module      String // attendance, results, fees, etc. (matches API spec module)
  action      String // view | create | update | delete | approve | publish | export | import
  description String?
  isSensitive Boolean  @default(false) @map("is_sensitive")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@index([module])
  @@index([module, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Binds a user to a role within a specific scope (e.g. HOD of CSE@MainCampus).
model UserRole {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  roleId      String    @map("role_id") @db.Uuid
  scopeType   ScopeType @map("scope_type")
  scopeId     String?   @map("scope_id") @db.Uuid // null when scopeType = GLOBAL
  instituteId String?   @map("institute_id") @db.Uuid // denormalized for tenant filtering
  isPrimary   Boolean   @default(false) @map("is_primary")
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  grantedById String?   @map("granted_by_id") @db.Uuid
  grantReason String?   @map("grant_reason")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role  @relation(fields: [roleId], references: [id], onDelete: Restrict)
  grantedBy User? @relation("RoleGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  // Partial unique (deletedAt IS NULL) — create via raw SQL migration:
  //   CREATE UNIQUE INDEX uq_user_role_scope_active
  //     ON user_roles(user_id, role_id, scope_type, scope_id)
  //     WHERE deleted_at IS NULL;
  @@unique([userId, roleId, scopeType, scopeId], name: "uq_user_role_scope")
  @@index([userId, isPrimary])
  @@index([roleId])
  @@index([instituteId, scopeType])
  @@index([scopeType, scopeId])
  @@index([deletedAt])
  @@map("user_roles")
}

// Additional data-access scopes a user holds independent of any role
// (e.g. cross-department visibility, exam-cell auditor access).
model UserScope {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  scopeType   ScopeType @map("scope_type")
  scopeId     String?   @map("scope_id") @db.Uuid
  instituteId String?   @map("institute_id") @db.Uuid
  reason      String?
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  grantedById String?   @map("granted_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("ScopeGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, scopeType, scopeId], name: "uq_user_scope")
  @@index([instituteId, scopeType])
  @@index([scopeType, scopeId])
  @@index([deletedAt])
  @@map("user_scopes")
}

model AuthCredential {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  passwordHash String    @map("password_hash")
  algorithm    String    @default("argon2id")
  rotatedAt    DateTime  @default(now()) @map("rotated_at")
  expiresAt    DateTime? @map("expires_at")
  isCurrent    Boolean   @default(true) @map("is_current")
