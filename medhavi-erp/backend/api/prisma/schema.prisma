  facultyAdvisorId String                  @map("faculty_advisor_id") @db.Uuid
  advisorFacultyId String                  @map("advisor_faculty_id") @db.Uuid
  studentId        String                  @map("student_id") @db.Uuid
  role             AdvisorRole             @default(PROGRAM_ADVISOR)
  academicYearId   String?                 @map("academic_year_id") @db.Uuid
  startDate        DateTime                @map("start_date") @db.Date
  endDate          DateTime?               @map("end_date") @db.Date
  status           AdvisorAssignmentStatus @default(ACTIVE)
  notes            String?                 @db.Text
  assignedByUserId String?                 @map("assigned_by_user_id") @db.Uuid
  metadata         Json?                   @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  institute      Institute      @relation(fields: [instituteId], references: [id], onDelete: Restrict)
  facultyAdvisor FacultyAdvisor @relation(fields: [facultyAdvisorId], references: [id], onDelete: Cascade)
  advisorFaculty Faculty        @relation("AdvisorStudentAdvisor", fields: [advisorFacultyId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  assignedBy     User?          @relation("AdvisorStudentAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  // student        Student                 @relation(...) — wired in Batch 3

  // --- Back-relations (hotfix) ---
  student Student @relation("AdvisorStudentStudent", fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([facultyAdvisorId, studentId, role, academicYearId])
  @@index([instituteId, status])
  @@index([advisorFacultyId, status])
  @@index([studentId, status])
  @@index([academicYearId])
  @@index([deletedAt])
  @@map("advisor_students")
}

